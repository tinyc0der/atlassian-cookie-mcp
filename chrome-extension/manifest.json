{
  "manifest_version": 3,
  "name": "Atlassian Cookie Sync",
  "version": "1.3.1",
  "description": "Sync Jira/Confluence session cookies to atlassian-browser-mcp (manual or auto on cookie change).",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["cookies", "activeTab", "nativeMessaging", "storage"],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "http://*.atlassian.net/*",
    "https://*.jira.com/*",
    "http://*.jira.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sync Atlassian cookies",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
