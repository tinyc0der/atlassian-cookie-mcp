{
  "manifest_version": 3,
  "name": "Atlassian Cookie Sync",
  "version": "1.2.0",
  "description": "Sync live Jira/Confluence cookies from the current tab to atlassian-browser-mcp via native messaging.",
  "key": "",
  "permissions": ["cookies", "activeTab", "nativeMessaging"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sync Atlassian cookies"
  }
}
