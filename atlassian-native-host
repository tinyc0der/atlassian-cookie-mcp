#!/usr/bin/env bash
# Chrome Native Messaging host launcher for atlassian-browser-mcp.
#
# Registered by `atlassian-cli install-host`. Chrome starts this process with
# a clean environment; JIRA_URL / CONFLUENCE_URL come from
# .atlassian-native-host-env.json (written at install time).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PY="$SCRIPT_DIR/.venv/bin/python"

if [[ ! -x "$VENV_PY" ]]; then
  # Fall back to python3 on PATH if the project venv is missing.
  VENV_PY="${PYTHON:-python3}"
fi

# Same CA-env scrub as atlassian-cli (sandbox-injected broken bundles break TLS).
exec env -u NODE_EXTRA_CA_CERTS -u SSL_CERT_FILE -u CODEX_CA_CERTIFICATE \
  "$VENV_PY" "$SCRIPT_DIR/atlassian_native_host.py" "$@"
