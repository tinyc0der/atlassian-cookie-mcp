__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
*.whl
dist/
build/
.eggs/
.venv/
# Local uv lockfile (this project is not distributed via a locked uv workspace).
uv.lock

# Env snapshot for Chrome-launched native messaging host (URLs + jar paths).
.atlassian-native-host-env.json

# Browser profile(s) — live credentials. Covers the automation profile and any
# timestamped .bak copies.
.atlassian-browser-profile*
# Session cookie jars and their backups — live credentials, never commit. Covers
# per-service files (.atlassian-browser-state-jira.json), the legacy single file,
# extensionless copies, and timestamped .bak backups.
.atlassian-browser-state*
# Cookie exports downloaded from the browser extension (live credentials).
atlassian-cookies*.json
# Personal / machine-local launchers that embed absolute paths or instance URLs.
start-codex.sh
atlassian-cli-codex
.env
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.omc/
